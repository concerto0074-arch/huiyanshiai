# 慧眼识癌项目 - 环境配置模板
# 使用方法：复制本文件为 .env 并填写实际内容

# ----------------------------------------------------------------
# AI 服务配置 (DeepSeek)
# ----------------------------------------------------------------
# 必填：DeepSeek API 密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 选填：DeepSeek API 基础地址 (默认为 https://api.deepseek.com/v1)
API_BASE_URL=https://api.deepseek.com/v1

# ----------------------------------------------------------------
# Flask 后端配置
# ----------------------------------------------------------------
# 运行环境 (development / production)
FLASK_ENV=development
# 调试模式 (True / False)
FLASK_DEBUG=True
# 运行端口
PORT=5000

# ----------------------------------------------------------------
# 数据库与前端配置 (生产环境必备)
# ----------------------------------------------------------------
# 前端 Vercel 域名（用于跨域限制，例如 https://huiyanshiai.vercel.app）
# 如果为 *，则允许所有来源跨域（适用于本地开发）
FRONTEND_URL=*

# 数据库连接字符串 (默认为本地 SQLite)
# Supabase/阿里云等请修改为: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///../data/patients.db

# ----------------------------------------------------------------
# 认证配置
# ----------------------------------------------------------------
# JWT 密钥（用于生成和验证登录态 Token）
JWT_SECRET=your_jwt_secret_here

# 管理员专属接口认证 Token
ADMIN_TOKEN=your_admin_token_here
