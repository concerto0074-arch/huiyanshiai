pamRespectsDendro = FALSE,
saveTOMs = TRUE,                   # 保存TOM矩阵
verbose = 3,                       #打印更多详细信息
maxBlockSize = 6000)               # 可以处理的数据集的最大基因数，默认5000
#blockwiseModules函数用于构建基因共表达网络，并将基因聚类成模块
# 所有模块个数和各个模块中基因数量
table(net$colors)
datout2=data.frame(as.matrix(net$colors))
View(datout2)
MEs = net$MEs # 模块特征向量
View(MEs)
View(net)
View(datout2)
