rf
importance(rf)
varImpPlot(rf)
pred1<-predict(rf,newdata=test)
Freq1<-table(pred1,test$V61)
tp<-as.data.frame(Freq1)[4,3]
tn<-as.data.frame(Freq1)[1,3]
fn<-as.data.frame(Freq1)[2,3]
fp<-as.data.frame(Freq1)[3,3]
p<-tp/(tp+fp)
r<-tp/(tp+fn)
f<-2/(1/p+1/r)
f
